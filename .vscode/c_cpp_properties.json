{
    "configurations": [
        {
            "name": "FunnyOS Cross",
            "includePath": [
                "${workspaceFolder}/src/common/**",
                "${workspaceFolder}/src/kernel/**"
            ],
            "compilerPath": "i686-elf-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-clang-x64",
            "compilerPathInCppPropertiesJson": "i686-elf-gcc",
            "mergeConfigurations": false,
            "recursiveIncludes": {
                "reduce": "default",
                "priority": "afterSystemIncludes",
                "order": "depthFirst"
            },
            "browse": {
                "limitSymbolsToIncludedHeaders": true
            },
            "compilerArgs": [
                "-ffreestanding",
                "-fno-pie",
                "-fno-stack-protector"
            ]
        }
    ],
    "version": 4
}
